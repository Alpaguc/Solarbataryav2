{
  "name": "solarbatarya-platform",
  "private": true,
  "version": "2.0.0",
  "description": "SolarBatarya moduler monorepo yapisi (web + api + simulation core)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace @solarbatarya/api",
    "dev:web": "npm run dev --workspace @solarbatarya/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:seed": "npm run db:seed --workspace @solarbatarya/api",
    "admin:ensure": "npm run admin:ensure --workspace @solarbatarya/api",
    "compare:legacy": "npm run compare:legacy --workspace @solarbatarya/api",
    "start:api": "npm run start --workspace @solarbatarya/api",
    "legacy:start": "node backend/server.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
